# Copy this file to .env.production and replace every replace-with-* value.
# Do not commit .env.production.

POSTGRES_DB=portfolio_cms
POSTGRES_USER=portfolio_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password

SERVER_PORT=8080
DB_URL=jdbc:postgresql://db:5432/portfolio_cms
DB_USERNAME=portfolio_app
DB_PASSWORD=replace-with-strong-postgres-password

CORS_ALLOWED_ORIGINS=https://your-domain.example
VITE_API_BASE_URL=
PORTFOLIO_API_BASE_URL=https://your-domain.example

ADMIN_SEED_ENABLED=false
ADMIN_SEED_EMAIL=admin@your-domain.example
ADMIN_SEED_PASSWORD=replace-with-temporary-admin-password

AUTH_JWT_ISSUER=portfolio-cms
AUTH_JWT_SECRET=replace-with-64-byte-random-secret
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=14

# Current MVP stores CV/media bytes in PostgreSQL. Keep this configured for
# future filesystem/object-storage migration; it is not mounted by default.
FILE_STORAGE_PATH=/var/lib/portfolio-cms/files
